APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=agency_core
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

N8N_API_TOKEN=your_secure_random_string_here

# N8N Webhooks (Sostituisci con i webhook reali generati da N8N)
# N8N_REGENERATE_SOCIAL_POST_WEBHOOK_URL=https://n8n.example.com/webhook/regenerate-post
N8N_GENERATE_SOCIAL_POST_WEBHOOK_URL=https://n8n.example.com/webhook/generate-post
# N8N_GENERATE_EDITORIAL_PLAN_WEBHOOK_URL=https://n8n.example.com/webhook/generate-plan
# N8N_SEND_WHATSAPP_REVIEW_WEBHOOK_URL=https://n8n.example.com/webhook/send-review
# N8N_PUBLISH_SOCIAL_POST_WEBHOOK_URL=https://n8n.example.com/webhook/publish-post

NEXTCLOUD_BASE_URL=https://cloud.tuodominio.it
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=
NEXTCLOUD_WEBDAV_PATH=/remote.php/dav/files
NEXTCLOUD_PHOTOS_ROOT=/FotoClienti
NEXTCLOUD_VIDEOS_ROOT=/VideoClienti
